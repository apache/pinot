<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
  <modelVersion>4.0.0</modelVersion>
  <parent>
    <artifactId>pinot-batch-ingestion</artifactId>
    <groupId>org.apache.pinot</groupId>
    <version>1.6.0-SNAPSHOT</version>
  </parent>

  <artifactId>pinot-batch-ingestion-spark-4</artifactId>
  <name>Pinot Batch Ingestion for Spark 4</name>
  <url>https://pinot.apache.org/</url>
  <properties>
    <pinot.root>${basedir}/../../..</pinot.root>
    <shade.phase.prop>package</shade.phase.prop>
    <!-- Apache Spark 4 requires JDK 17+; Pinot compiles the Spark 4 jars with release=21
         (class file 65). The module is only registered in the reactor under a JDK-21+ profile
         in pinot-batch-ingestion/pom.xml. The property here hardens the compile target if
         someone invokes this module directly. -->
    <jdk.version>21</jdk.version>
  </properties>

  <build>
    <plugins>
      <!-- Hard-fail early with a clear message on JDK 17/11 or Scala 2.12 instead of letting
           an obscure Maven resolution error leak through. The parent-pom module activation
           gates this module out of older builds, but this enforcer catches someone invoking
           `./mvnw -pl pinot-plugins/pinot-batch-ingestion/pinot-batch-ingestion-spark-4`
           directly on an older JDK or under -Pscala-2.12. -->
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-enforcer-plugin</artifactId>
        <executions>
          <execution>
            <id>enforce-spark4-prereqs</id>
            <goals>
              <goal>enforce</goal>
            </goals>
            <configuration>
              <rules>
                <requireJavaVersion>
                  <version>[21,)</version>
                  <message>pinot-batch-ingestion-spark-4 requires JDK 21 or newer. Use pinot-batch-ingestion-spark-3 for older JDKs.</message>
                </requireJavaVersion>
                <requireProperty>
                  <property>scala.compat.version</property>
                  <regex>^2\.13$</regex>
                  <regexMessage>pinot-batch-ingestion-spark-4 requires Scala 2.13 (Apache Spark 4 does not publish Scala 2.12 artifacts). Remove -Pscala-2.12 or exclude this module.</regexMessage>
                </requireProperty>
              </rules>
              <fail>true</fail>
            </configuration>
          </execution>
        </executions>
      </plugin>
    </plugins>
  </build>

  <dependencies>
    <!-- pinot-core (provided) is inherited via pinot-plugins/pinot-batch-ingestion/pom.xml;
         testng (test) is inherited via pinot-plugins/pom.xml. No need to declare them here. -->
    <dependency>
      <groupId>org.apache.pinot</groupId>
      <artifactId>pinot-batch-ingestion-spark-base</artifactId>
    </dependency>
    <dependency>
      <groupId>org.apache.spark</groupId>
      <artifactId>spark-core_${scala.compat.version}</artifactId>
      <version>${spark4.version}</version>
      <scope>provided</scope>
      <exclusions>
        <exclusion>
          <groupId>commons-logging</groupId>
          <artifactId>commons-logging</artifactId>
        </exclusion>
        <exclusion>
          <groupId>log4j</groupId>
          <artifactId>log4j</artifactId>
        </exclusion>
        <exclusion>
          <groupId>org.slf4j</groupId>
          <artifactId>slf4j-log4j12</artifactId>
        </exclusion>
        <exclusion>
          <groupId>org.lz4</groupId>
          <artifactId>lz4-java</artifactId>
        </exclusion>
      </exclusions>
    </dependency>
    <!-- Explicit spark-launcher override to prevent the root pom's Spark-3 dependencyManagement
         pin from forcing spark-launcher back to 3.5.8 alongside spark-core 4.x. -->
    <dependency>
      <groupId>org.apache.spark</groupId>
      <artifactId>spark-launcher_${scala.compat.version}</artifactId>
      <version>${spark4.version}</version>
      <scope>provided</scope>
    </dependency>
    <dependency>
      <groupId>org.scala-lang</groupId>
      <artifactId>scala-library</artifactId>
      <scope>provided</scope>
    </dependency>

    <!-- For testing import of csv files -->
    <dependency>
      <groupId>org.apache.pinot</groupId>
      <artifactId>pinot-csv</artifactId>
      <scope>test</scope>
    </dependency>

    <!-- Spark 4 uses Jakarta EE 9 namespace (jakarta.servlet.*). The root pom pins
         jakarta.servlet-api to 4.0.4 (Jakarta EE 8, still in javax.servlet.* namespace) for the
         rest of the Pinot build. Required even though the Spark UI is disabled in tests, because
         Spark's MetricsServlet loads jakarta.servlet.Servlet unconditionally during startup. -->
    <dependency>
      <groupId>jakarta.servlet</groupId>
      <artifactId>jakarta.servlet-api</artifactId>
      <version>5.0.0</version>
      <scope>test</scope>
    </dependency>
  </dependencies>

  <profiles>
    <profile>
      <id>pinot-fastdev</id>
      <properties>
        <shade.phase.prop>none</shade.phase.prop>
      </properties>
    </profile>
  </profiles>
</project>
