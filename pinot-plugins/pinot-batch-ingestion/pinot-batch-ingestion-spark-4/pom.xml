<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
  <modelVersion>4.0.0</modelVersion>
  <parent>
    <artifactId>pinot-batch-ingestion</artifactId>
    <groupId>org.apache.pinot</groupId>
    <version>1.6.0-SNAPSHOT</version>
  </parent>

  <artifactId>pinot-batch-ingestion-spark-4</artifactId>
  <name>Pinot Batch Ingestion for Spark 4</name>
  <url>https://pinot.apache.org/</url>
  <properties>
    <pinot.root>${basedir}/../../..</pinot.root>
    <shade.phase.prop>package</shade.phase.prop>
    <!-- Spark 4.1+ depends on netty 4.2.x (io.netty.channel.kqueue.KQueueIoHandler and
         io.netty.channel.epoll.EpollIoHandler are new APIs introduced in 4.2). Pinot-wide
         netty.version is pinned to 4.1.x for the rest of the build; locally override it for
         this module so:
           (a) the embedded SparkContext in SparkSegmentGenerationJobRunnerTest can construct
               its NettyRpcEnv without NoClassDefFoundError on macOS (kqueue) / Linux (epoll);
           (b) the production shaded jar (assembled by pinot-distribution/pinot-assembly.xml
               under `plugins-external/pinot-batch-ingestion/pinot-batch-ingestion-spark-4/`)
               carries netty 4.2.x at runtime, matching what Spark 4.1+ on the user's cluster
               itself bundles — so the shaded plugin and Spark agree on a single netty.
         Validated against spark4.version=4.1.1 (which depends on netty-all:4.2.7.Final). If
         spark4.version is bumped, re-validate that the new Spark patch's transitive netty is
         still in the 4.2.x line; the SparkVersionAlignmentTest assertion in this module's
         tests pins the major.minor pair so a future bump that goes to 4.3.x or back to 4.1.x
         fails the build immediately. -->
    <netty.version>4.2.7.Final</netty.version>
  </properties>

  <build>
    <plugins>
      <!-- Hard-fail early with a clear message under -Pscala-2.12 instead of letting an
           obscure Maven resolution error leak through. JDK 21+ is already enforced by the
           root pom's requireJavaVersion rule, so we only need the Scala compat check here. -->
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-enforcer-plugin</artifactId>
        <executions>
          <execution>
            <id>enforce-spark4-prereqs</id>
            <goals>
              <goal>enforce</goal>
            </goals>
            <configuration>
              <rules>
                <requireProperty>
                  <property>scala.compat.version</property>
                  <regex>^2\.13$</regex>
                  <regexMessage>pinot-batch-ingestion-spark-4 requires Scala 2.13 (Apache Spark 4 does not publish Scala 2.12 artifacts). Remove -Pscala-2.12 or exclude this module.</regexMessage>
                </requireProperty>
              </rules>
              <fail>true</fail>
            </configuration>
          </execution>
        </executions>
      </plugin>
    </plugins>
  </build>

  <dependencies>
    <!-- pinot-core (provided) is inherited via pinot-plugins/pinot-batch-ingestion/pom.xml;
         testng (test) is inherited via pinot-plugins/pom.xml. No need to declare them here. -->
    <dependency>
      <groupId>org.apache.pinot</groupId>
      <artifactId>pinot-batch-ingestion-spark-base</artifactId>
    </dependency>
    <dependency>
      <groupId>org.apache.spark</groupId>
      <artifactId>spark-core_${scala.compat.version}</artifactId>
      <version>${spark4.version}</version>
      <scope>provided</scope>
      <exclusions>
        <exclusion>
          <groupId>commons-logging</groupId>
          <artifactId>commons-logging</artifactId>
        </exclusion>
        <exclusion>
          <groupId>log4j</groupId>
          <artifactId>log4j</artifactId>
        </exclusion>
        <exclusion>
          <groupId>org.slf4j</groupId>
          <artifactId>slf4j-log4j12</artifactId>
        </exclusion>
        <exclusion>
          <groupId>org.lz4</groupId>
          <artifactId>lz4-java</artifactId>
        </exclusion>
      </exclusions>
    </dependency>
    <!-- Explicit spark-launcher override to prevent the root pom's Spark-3 dependencyManagement
         pin from forcing spark-launcher back to 3.5.8 alongside spark-core 4.x. -->
    <dependency>
      <groupId>org.apache.spark</groupId>
      <artifactId>spark-launcher_${scala.compat.version}</artifactId>
      <version>${spark4.version}</version>
      <scope>provided</scope>
    </dependency>
    <dependency>
      <groupId>org.scala-lang</groupId>
      <artifactId>scala-library</artifactId>
      <scope>provided</scope>
    </dependency>

    <!-- For testing import of csv files -->
    <dependency>
      <groupId>org.apache.pinot</groupId>
      <artifactId>pinot-csv</artifactId>
      <scope>test</scope>
    </dependency>

    <!-- Spark 4 uses Jakarta EE 9 namespace (jakarta.servlet.*). The root pom pins
         jakarta.servlet-api to 4.0.4 (Jakarta EE 8, still in javax.servlet.* namespace) for the
         rest of the Pinot build. Required even though the Spark UI is disabled in tests, because
         Spark's MetricsServlet loads jakarta.servlet.Servlet unconditionally during startup. -->
    <dependency>
      <groupId>jakarta.servlet</groupId>
      <artifactId>jakarta.servlet-api</artifactId>
      <version>5.0.0</version>
      <scope>test</scope>
    </dependency>

  </dependencies>

  <profiles>
    <profile>
      <id>pinot-fastdev</id>
      <properties>
        <shade.phase.prop>none</shade.phase.prop>
      </properties>
    </profile>
  </profiles>
</project>
