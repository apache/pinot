<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
  <modelVersion>4.0.0</modelVersion>
  <parent>
    <artifactId>pinot-batch-ingestion</artifactId>
    <groupId>org.apache.pinot</groupId>
    <version>1.6.0-SNAPSHOT</version>
  </parent>

  <artifactId>pinot-batch-ingestion-spark-4</artifactId>
  <name>Pinot Batch Ingestion for Spark 4</name>
  <url>https://pinot.apache.org/</url>
  <properties>
    <pinot.root>${basedir}/../../..</pinot.root>
    <shade.phase.prop>package</shade.phase.prop>
    <!-- Spark 4.1+ depends on netty 4.2.x (io.netty.channel.kqueue.KQueueIoHandler and
         io.netty.channel.epoll.EpollIoHandler are new APIs introduced in 4.2). Pinot-wide
         netty.version is pinned to 4.1.x for the rest of the build. Override it locally for
         this module's *test* classpath only — at production runtime the spark-core
         dependency is `provided`, so the shaded jar carries no netty at all and relies on
         the user's Spark 4 cluster to supply 4.2.x itself. The override matters because:
           (a) the embedded SparkContext in SparkSegmentGenerationJobRunnerTest needs netty
               4.2.x on the *test* classpath to construct its NettyRpcEnv without
               NoClassDefFoundError on macOS (kqueue) / Linux (epoll);
           (b) any netty 4.2-only API this module's *production* sources use must compile
               against 4.2.x even though it ships against `provided` scope.
         Validated against spark4.version=4.1.1 (which depends on netty-all:4.2.7.Final). If
         spark4.version is bumped, re-validate that the new Spark patch's transitive netty is
         still in the 4.2.x line; SparkVersionAlignmentTest pins every netty module's
         artifactVersion so a future bump that goes to 4.3.x or back to 4.1.x fails the
         build immediately. -->
    <netty.version>4.2.7.Final</netty.version>
    <!-- Spark 4 uses Jakarta EE 9 namespace (jakarta.servlet.* package). The root pom pins
         jakarta.servlet-api to 4.0.4 (Jakarta EE 8, still in javax.servlet.* namespace, marked
         DO NOT UPGRADE for the rest of the build). Locally override the property so the
         test dependency below picks up 5.0.0 from the inherited <dependencyManagement>
         resolution — declaring the version inline trips Pinot's custom dependency rule.
         The override is module-scoped; the rest of Pinot stays on 4.0.4. -->
    <jakarta.servlet-api.version>5.0.0</jakarta.servlet-api.version>
    <!-- The root pom's <dependencyManagement> pins org.apache.spark:* to ${spark3.version}
         (currently 3.5.8). For this Spark 4 module we need 4.1.1; rather than redeclare each
         spark-* dependency with an inline <version> (which trips PinotCustomDependencyVersionRule),
         override the spark3.version property locally so the inherited <dependencyManagement>
         resolution picks up 4.1.1 for spark-core / spark-sql / spark-launcher / etc. The
         property name is a misnomer here but the alternative (forking the dependencyManagement
         block in the root pom or one-off-overriding each artifact) is worse. -->
    <spark3.version>${spark4.version}</spark3.version>
  </properties>

  <build>
    <plugins>
      <!-- Hard-fail early with a clear message under -Pscala-2.12 instead of letting an
           obscure Maven resolution error leak through. JDK 21+ is already enforced by the
           root pom's requireJavaVersion rule, so we only need the Scala compat check here. -->
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-enforcer-plugin</artifactId>
        <executions>
          <execution>
            <id>enforce-spark4-prereqs</id>
            <goals>
              <goal>enforce</goal>
            </goals>
            <configuration>
              <rules>
                <requireProperty>
                  <property>scala.compat.version</property>
                  <regex>^2\.13$</regex>
                  <regexMessage>pinot-batch-ingestion-spark-4 requires Scala 2.13 (Apache Spark 4 does not publish Scala 2.12 artifacts). Remove -Pscala-2.12 or exclude this module.</regexMessage>
                </requireProperty>
              </rules>
              <fail>true</fail>
            </configuration>
          </execution>
        </executions>
      </plugin>
    </plugins>
  </build>

  <dependencies>
    <!-- pinot-core (provided) is inherited via pinot-plugins/pinot-batch-ingestion/pom.xml;
         testng (test) is inherited via pinot-plugins/pom.xml. No need to declare them here. -->
    <dependency>
      <groupId>org.apache.pinot</groupId>
      <artifactId>pinot-batch-ingestion-spark-base</artifactId>
    </dependency>
    <dependency>
      <groupId>org.apache.spark</groupId>
      <artifactId>spark-core_${scala.compat.version}</artifactId>
      <scope>provided</scope>
      <exclusions>
        <exclusion>
          <groupId>commons-logging</groupId>
          <artifactId>commons-logging</artifactId>
        </exclusion>
        <exclusion>
          <groupId>log4j</groupId>
          <artifactId>log4j</artifactId>
        </exclusion>
        <exclusion>
          <groupId>org.slf4j</groupId>
          <artifactId>slf4j-log4j12</artifactId>
        </exclusion>
        <exclusion>
          <groupId>org.lz4</groupId>
          <artifactId>lz4-java</artifactId>
        </exclusion>
      </exclusions>
    </dependency>
    <dependency>
      <groupId>org.apache.spark</groupId>
      <artifactId>spark-launcher_${scala.compat.version}</artifactId>
      <scope>provided</scope>
    </dependency>
    <dependency>
      <groupId>org.scala-lang</groupId>
      <artifactId>scala-library</artifactId>
      <scope>provided</scope>
    </dependency>

    <!-- For testing import of csv files -->
    <dependency>
      <groupId>org.apache.pinot</groupId>
      <artifactId>pinot-csv</artifactId>
      <scope>test</scope>
    </dependency>

    <!-- Spark 4 uses Jakarta EE 9 namespace (jakarta.servlet.*). Required even though the
         Spark UI is disabled in tests, because Spark's MetricsServlet loads
         jakarta.servlet.Servlet unconditionally during startup. The version (5.0.0) comes
         from the local jakarta.servlet-api.version property override in <properties> above —
         declaring it inline here would trip PinotCustomDependencyVersionRule. -->
    <dependency>
      <groupId>jakarta.servlet</groupId>
      <artifactId>jakarta.servlet-api</artifactId>
      <scope>test</scope>
    </dependency>

  </dependencies>

  <profiles>
    <profile>
      <id>pinot-fastdev</id>
      <properties>
        <shade.phase.prop>none</shade.phase.prop>
      </properties>
    </profile>
  </profiles>
</project>
