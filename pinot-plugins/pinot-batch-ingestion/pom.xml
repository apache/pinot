<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
  <modelVersion>4.0.0</modelVersion>
  <parent>
    <artifactId>pinot-plugins</artifactId>
    <groupId>org.apache.pinot</groupId>
    <version>1.6.0-SNAPSHOT</version>
  </parent>
  <artifactId>pinot-batch-ingestion</artifactId>
  <packaging>pom</packaging>
  <name>Pinot Batch Ingestion</name>
  <url>https://pinot.apache.org/</url>
  <properties>
    <pinot.root>${basedir}/../..</pinot.root>
    <plugin.type>pinot-batch-ingestion</plugin.type>
  </properties>

  <modules>
    <module>pinot-batch-ingestion-common</module>
    <module>pinot-batch-ingestion-spark-base</module>
    <module>pinot-batch-ingestion-spark-3</module>

    <module>pinot-batch-ingestion-hadoop</module>
    <module>pinot-batch-ingestion-standalone</module>
  </modules>

  <profiles>
    <!-- Apache Spark 4 requires JDK 17+ and Scala 2.13 only. Register the Spark 4 batch
         ingestion plugin only when the active JDK is 21 or later; on JDK 11/17 the module is
         absent from the reactor entirely. Spark 3 users on older JDKs continue to build
         pinot-batch-ingestion-spark-3 as before. -->
    <profile>
      <id>pinot-batch-ingestion-spark-4</id>
      <activation>
        <jdk>[21,)</jdk>
      </activation>
      <modules>
        <module>pinot-batch-ingestion-spark-4</module>
      </modules>
    </profile>
  </profiles>

  <dependencies>
    <dependency>
      <groupId>org.apache.pinot</groupId>
      <artifactId>pinot-core</artifactId>
      <scope>provided</scope>
    </dependency>
  </dependencies>
</project>
