<assembly
    xmlns="http://maven.apache.org/plugins/maven-assembly-plugin/assembly/1.1.2"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://maven.apache.org/plugins/maven-assembly-plugin/assembly/1.1.2 http://maven.apache.org/xsd/assembly-1.1.2.xsd">
  <id>bin</id>
  <formats>
    <format>tar.gz</format>
    <format>dir</format>
  </formats>
  <includeBaseDirectory>true</includeBaseDirectory>

  <files>
    <!-- Rename LICENSE-binary, NOTICE-binary to LICENSE, NOTICE and include them to a distribution tarbell -->
    <file>
      <source>${pinot.root}/LICENSE-binary</source>
      <destName>LICENSE</destName>
    </file>
    <file>
      <source>${pinot.root}/NOTICE-binary</source>
      <destName>NOTICE</destName>
    </file>
    <!-- Include Pinot All-in-one jar -->
    <file>
      <source>${pinot.root}/pinot-distribution/target/pinot-distribution-${project.version}-shaded.jar</source>
      <destName>lib/pinot-all-${project.version}-jar-with-dependencies.jar</destName>
    </file>
    <!-- Start Include Pinot External Plugins (shaded jars, not converted to zip layout) -->
    <file>
      <source>
        ${pinot.root}/pinot-plugins/pinot-batch-ingestion/pinot-batch-ingestion-hadoop/target/pinot-batch-ingestion-hadoop-${project.version}-shaded.jar
      </source>
      <destName>
        plugins-external/pinot-batch-ingestion/pinot-batch-ingestion-hadoop/pinot-batch-ingestion-hadoop-${project.version}-shaded.jar
      </destName>
    </file>
    <file>
      <source>
        ${pinot.root}/pinot-plugins/pinot-batch-ingestion/pinot-batch-ingestion-spark-3/target/pinot-batch-ingestion-spark-3-${project.version}-shaded.jar
      </source>
      <destName>
        plugins-external/pinot-batch-ingestion/pinot-batch-ingestion-spark-3/pinot-batch-ingestion-spark-3-${project.version}-shaded.jar
      </destName>
    </file>
    <!-- End Include Pinot External Plugins-->
    <!--
      Plugin verifier: a standalone main-class tool used to validate plugin loading against a
      built distribution (lib/pinot-all.jar + plugins/). Ships as a separate jar in lib/ —
      not included in the shaded uber-jar so its classes don't leak into the broker / server
      / controller / minion classpath. See bin/verify-plugins.sh.
    -->
    <file>
      <source>${pinot.root}/pinot-plugin-verifier/target/pinot-plugin-verifier-${project.version}.jar</source>
      <destName>lib/pinot-plugin-verifier-${project.version}.jar</destName>
    </file>
    <file>
      <source>${pinot.root}/pinot-plugin-verifier/src/main/resources/bin/verify-plugins.sh</source>
      <destName>bin/verify-plugins.sh</destName>
      <fileMode>0755</fileMode>
    </file>
  </files>
  <dependencySets>
    <!-- Unpack plugin zips into plugins/ directory -->
    <dependencySet>
      <outputDirectory>plugins</outputDirectory>
      <useProjectArtifact>false</useProjectArtifact>
      <unpack>true</unpack>
      <scope>provided</scope>
      <includes>
        <include>org.apache.pinot:pinot-kafka-3.0:zip:plugin</include>
        <include>org.apache.pinot:pinot-kinesis:zip:plugin</include>
        <include>org.apache.pinot:pinot-pulsar:zip:plugin</include>
        <include>org.apache.pinot:pinot-batch-ingestion-standalone:zip:plugin</include>
        <include>org.apache.pinot:pinot-adls:zip:plugin</include>
        <include>org.apache.pinot:pinot-gcs:zip:plugin</include>
        <include>org.apache.pinot:pinot-hdfs:zip:plugin</include>
        <include>org.apache.pinot:pinot-s3:zip:plugin</include>
        <include>org.apache.pinot:pinot-azure:zip:plugin</include>
        <include>org.apache.pinot:pinot-avro:zip:plugin</include>
        <include>org.apache.pinot:pinot-clp-log:zip:plugin</include>
        <include>org.apache.pinot:pinot-confluent-avro:zip:plugin</include>
        <include>org.apache.pinot:pinot-confluent-json:zip:plugin</include>
        <include>org.apache.pinot:pinot-confluent-protobuf:zip:plugin</include>
        <include>org.apache.pinot:pinot-csv:zip:plugin</include>
        <include>org.apache.pinot:pinot-json:zip:plugin</include>
        <include>org.apache.pinot:pinot-parquet:zip:plugin</include>
        <include>org.apache.pinot:pinot-orc:zip:plugin</include>
        <include>org.apache.pinot:pinot-thrift:zip:plugin</include>
        <include>org.apache.pinot:pinot-protobuf:zip:plugin</include>
        <include>org.apache.pinot:pinot-arrow:zip:plugin</include>
        <include>org.apache.pinot:pinot-minion-builtin-tasks:zip:plugin</include>
        <include>org.apache.pinot:pinot-yammer:zip:plugin</include>
        <include>org.apache.pinot:pinot-dropwizard:zip:plugin</include>
        <include>org.apache.pinot:pinot-segment-writer-file-based:zip:plugin</include>
        <include>org.apache.pinot:pinot-segment-uploader-default:zip:plugin</include>
        <include>org.apache.pinot:pinot-timeseries-m3ql:zip:plugin</include>
      </includes>
    </dependencySet>
  </dependencySets>

  <fileSets>
    <!-- Rename licenses-binary directory to licenses and include it to a distribution tarbell -->
    <fileSet>
      <useDefaultExcludes>false</useDefaultExcludes>
      <directory>${pinot.root}/licenses-binary</directory>
      <outputDirectory>licenses</outputDirectory>
    </fileSet>
    <fileSet>
      <useDefaultExcludes>false</useDefaultExcludes>
      <directory>${pinot.root}/pinot-tools/src/main/resources/conf</directory>
      <outputDirectory>conf</outputDirectory>
    </fileSet>
    <fileSet>
      <useDefaultExcludes>false</useDefaultExcludes>
      <directory>${pinot.root}/pinot-tools/src/main/resources/examples</directory>
      <outputDirectory>examples/</outputDirectory>
    </fileSet>
    <fileSet>
      <useDefaultExcludes>false</useDefaultExcludes>
      <directory>${pinot.root}/pinot-tools/target/pinot-tools-pkg/bin</directory>
      <outputDirectory>bin</outputDirectory>
      <fileMode>0755</fileMode>
    </fileSet>
  </fileSets>
</assembly>
