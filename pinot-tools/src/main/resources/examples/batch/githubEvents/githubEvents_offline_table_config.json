{
  "tableName": "githubEvents",
  "tableType": "OFFLINE",
  "tenants": {
  },
  "segmentsConfig": {
    "replication": "1",
    "timeColumnName": "created_at_timestamp"
  },
  "tableIndexConfig": {
    "loadMode": "MMAP",
    "noDictionaryColumns": [
      "actor",
      "repo",
      "payload"
    ],
    "jsonIndexConfigs": {
      "actor": {},
      "repo": {},
      "payload": {}
    }
  },
  "ingestionConfig": {
    "batchIngestionConfig": {
      "segmentIngestionType": "REFRESH"
    },
    "transformConfigs": [
      {
        "columnName": "created_at_timestamp",
        "transformFunction": "fromDateTime(created_at, 'yyyy-MM-dd''T''HH:mm:ss''Z''')"
      }
    ]
  },
  "metadata": {
    "customConfigs": {
    }
  }
}
